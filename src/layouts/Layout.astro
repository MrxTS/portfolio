---
interface Props {
  title?: string;
}
const { title = "Kamui — Portfolio" } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Software Test Engineer & iOS Developer — Portfolio von Kamui" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --border: #21262d;
    --border-subtle: #30363d;
    --text-primary: #e6edf3;
    --text-secondary: #8b949e;
    --text-subdued: #6e7681;
    --accent-blue: #58a6ff;
    --accent-green: #7ee787;
    --accent-red: #f78166;
    --accent-purple: #d2a8ff;
    --font: 'Fira Code', monospace;
    --max-width: 800px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text-primary);
    font-family: var(--font);
    line-height: 1.6;
  }
</style>
