---
const links = [
  { label: "email →", href: "mailto:deine@email.de", primary: true },
  { label: "github", href: "https://github.com/MrxTS", primary: false },
  { label: "linkedin", href: "https://linkedin.com/in/dein-profil", primary: false },
];
---

<section id="contact">
  <span class="comment">// contact</span>
  <p class="text">Interesse? Schreib mir gerne.</p>
  <div class="links">
    {links.map((l) => (
      <a href={l.href} class={l.primary ? "btn-primary" : "btn-secondary"} target="_blank" rel="noopener noreferrer">
        {l.label}
      </a>
    ))}
  </div>
</section>

<style>
  section {
    padding: 2.5rem 2rem;
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .comment {
    color: var(--text-subdued);
    font-size: 0.7rem;
    display: block;
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }
  .text {
    color: var(--text-secondary);
    font-size: 0.82rem;
    margin-bottom: 1.25rem;
  }
  .links { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .btn-primary {
    background: var(--accent-blue);
    color: var(--bg);
    padding: 0.4rem 1rem;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 700;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-secondary {
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    padding: 0.4rem 1rem;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.75rem;
    transition: color 0.15s;
  }
  .btn-secondary:hover { color: var(--text-primary); }
</style>
